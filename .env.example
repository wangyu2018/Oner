# Oner 部署环境变量配置
# 复制此文件为 .env 并修改以下值

# JWT密钥（必填，用于Token签名，请使用随机长字符串）
JWT_SECRET=your-random-secret-key-here

# 数据库路径（容器内路径，通过volume映射持久化）
DB_PATH=/data/oner.db

# 后端端口
PORT=3000

# 前端访问端口（nginx对外暴露端口）
APP_PORT=8080

# 运行环境
NODE_ENV=production

# ===== 微信小程序配置（小程序上线时必填） =====
# WX_APPID: 小程序管理后台 → 开发 → 开发设置 → AppID
# WX_APPSECRET: 同上位置 → AppSecret（需扫码重置）
WX_APPID=
WX_APPSECRET=
