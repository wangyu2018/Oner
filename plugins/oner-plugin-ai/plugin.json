{
  "id": "oner.plugin.ai",
  "name": "AI 智能助手",
  "version": "1.0.0",
  "type": "feature",
  "required": false,
  "description": "AI 对话、笔记润色、内容拆解、智能总结、分类分析等功能。支持多模型切换和流式输出。",
  "author": "Oner Team",
  "icon": "🤖",
  "category": "productivity",
  "tags": ["AI", "智能", "对话", "润色"],

  "dependencies": ["oner.plugin.core-notes"],

  "permissions": [
    "notes:read",
    "ai:chat",
    "ai:polish",
    "ai:summarize"
  ],

  "frontend": {
    "entry": "./frontend/index.jsx",
    "routes": [
      {
        "path": "/ai",
        "component": "./frontend/pages/AIChat.jsx",
        "exact": true,
        "title": "AI 对话"
      }
    ],
    "sidebar": [
      {
        "id": "ai-chat",
        "label": "AI 助手",
        "icon": "Sparkles",
        "path": "/ai",
        "priority": 80,
        "slot": "sidebar.main"
      }
    ],
    "commands": [
      {
        "id": "ai.chat",
        "title": "AI 对话",
        "icon": "Sparkles",
        "shortcut": "Ctrl+I",
        "slot": "commandbar.quick"
      },
      {
        "id": "ai.polish",
        "title": "AI 润色当前笔记",
        "icon": "Wand2",
        "slot": "commandbar.note"
      }
    ],
    "floatingBubbles": [
      {
        "id": "ai-quick-action",
        "icon": "Sparkles",
        "position": "bottom-right",
        "priority": 10
      }
    ]
  },

  "backend": {
    "entry": "./backend/index.js",
    "routes": [
      {
        "path": "/api/ai",
        "file": "./backend/routes/ai.js"
      }
    ]
  },

  "config": {
    "schema": {
      "provider": {
        "type": "select",
        "options": ["openai", "deepseek", "qwen", "custom"],
        "default": "deepseek"
      },
      "model": {
        "type": "string",
        "default": "deepseek-chat"
      },
      "temperature": {
        "type": "number",
        "default": 0.7,
        "min": 0,
        "max": 2
      },
      "maxTokens": {
        "type": "number",
        "default": 2000
      }
    }
  },

  "metadata": {
    "createdAt": "2026-06-13",
    "updatedAt": "2026-06-13"
  }
}
