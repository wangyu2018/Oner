{
  "name": "oner-desktop",
  "version": "1.0.0",
  "description": "Oner - 轻量备忘桌面版",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "NODE_ENV=development electron .",
    "generate-icons": "node scripts/generate-icons.js",
    "build": "npm run build:frontend && electron-builder",
    "build:frontend": "cd ../frontend && npm run build",
    "build:win": "npm run build:frontend && electron-builder --win",
    "build:mac": "npm run build:frontend && electron-builder --mac",
    "build:linux": "npm run build:frontend && electron-builder --linux"
  },
  "dependencies": {
    "auto-launch": "^5.0.6",
    "electron-store": "^8.1.0",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "build": {
    "appId": "com.oner.desktop",
    "productName": "Oner",
    "copyright": "Copyright © 2024 Oner",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "icons/**/*",
      "node_modules/**/*",
      "../frontend/dist/**/*"
    ],
    "asar": true,
    "asarUnpack": [
      "node_modules/auto-launch/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "icons/icon.svg",
      "artifactName": "${productName}-${version}-${arch}-Setup.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": true,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Oner",
      "installerIcon": "icons/icon.svg",
      "uninstallerIcon": "icons/icon.svg",
      "installerHeaderIcon": "icons/icon.svg",
      "allowElevation": true
    },
    "portable": {
      "artifactName": "${productName}-${version}-Portable.${ext}"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "icons/icon.svg",
      "category": "public.app-category.productivity"
    },
    "dmg": {
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "icons/icon.svg",
      "category": "Office",
      "desktop": {
        "StartupNotify": "true",
        "Terminal": "false",
        "MimeType": "x-scheme-handler/oner"
      }
    },
    "publish": {
      "provider": "github",
      "owner": "oner",
      "repo": "oner-desktop"
    }
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs"
}
