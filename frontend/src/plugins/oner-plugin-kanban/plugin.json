{
  "id": "oner.plugin.kanban",
  "name": "看板视图",
  "version": "1.0.0",
  "type": "feature",
  "required": false,
  "description": "泳道看板、状态流转、拖拽排序。支持自定义列和 WIP 限制。",
  "author": "Oner Team",
  "icon": "📋",
  "category": "productivity",
  "tags": ["看板", "泳道", "拖拽", "状态"],

  "dependencies": ["oner.plugin.core-notes"],

  "permissions": [
    "notes:read",
    "notes:write"
  ],

  "frontend": {
    "entry": "./frontend/index.jsx",
    "routes": [
      {
        "path": "/board",
        "component": "./frontend/pages/BoardPage.jsx",
        "exact": true,
        "title": "看板"
      }
    ],
    "sidebar": [
      {
        "id": "kanban-board",
        "label": "看板",
        "icon": "Columns",
        "path": "/board",
        "priority": 90,
        "slot": "sidebar.main"
      }
    ],
    "commands": [
      {
        "id": "board.open",
        "title": "打开看板",
        "icon": "Columns",
        "slot": "commandbar.views"
      }
    ]
  },

  "config": {
    "schema": {
      "columns": {
        "type": "array",
        "default": ["memo", "todo", "in_progress", "done"],
        "description": "看板列定义"
      },
      "wipLimit": {
        "type": "number",
        "default": 0,
        "description": "WIP 限制（0=不限制）"
      },
      "showArchived": {
        "type": "boolean",
        "default": false
      }
    }
  },

  "metadata": {
    "createdAt": "2026-06-13",
    "updatedAt": "2026-06-13"
  }
}
