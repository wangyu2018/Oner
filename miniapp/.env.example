# Oner 小程序环境变量配置
# 复制此文件为 .env.production 或 .env 并修改以下值

# 后端 API 地址（生产环境 HTTPS 域名）
TARO_APP_API_BASE=https://your-domain.com/api

# 微信订阅消息模板 ID（需在微信小程序后台「公共模板库」申请）
# 待办到期提醒模板
TARO_APP_WX_TMPL_TODO_DUE=

# 备忘完成回执模板
TARO_APP_WX_TMPL_MEMO_DONE=

# 每日效率汇总模板
TARO_APP_WX_TMPL_DAILY_SUMMARY=
# Oner 小程序环境变量配置
# 复制此文件为 .env.production 或 .env 并修改以下值

# 后端 API 地址（生产环境 HTTPS 域名）
TARO_APP_API_BASE=https://your-domain.com/api

# 微信订阅消息模板 ID（需在微信小程序后台配置）
TARO_APP_WX_TMPL_TODO_DUE=
